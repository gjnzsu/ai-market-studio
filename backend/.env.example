# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# GPT-4o model to use
OPENAI_MODEL=gpt-4o

# OpenAI base URL (override to use ai-gateway-service)
OPENAI_BASE_URL=https://api.openai.com/v1

# exchangerate.host API key (required — free tier at https://exchangerate.host)
EXCHANGERATE_API_KEY=your_key_here

# Set to true to use MockConnector instead of live data (recommended for tests/dev)
USE_MOCK_CONNECTOR=false

# Set to true to use MockNewsConnector instead of live RSS feeds
USE_MOCK_NEWS_CONNECTOR=true

# Allowed CORS origins (comma-separated). Configure for frontend service.
CORS_ORIGINS=http://localhost:8080,http://ai-market-studio-ui

# Max historical days for dashboard queries
MAX_HISTORICAL_DAYS=7

# RAG service URL (external microservice)
RAG_SERVICE_URL=http://ai-rag-service:8000

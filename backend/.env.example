# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# exchangerate.host API key (required — free tier at https://exchangerate.host)
EXCHANGERATE_API_KEY=your_key_here

# Set to true to use MockConnector instead of live data (recommended for tests/dev)
USE_MOCK_CONNECTOR=false

# GPT-4o model to use
OPENAI_MODEL=gpt-4o

# Allowed CORS origins (comma-separated). Use * for local dev only.
CORS_ORIGINS=*

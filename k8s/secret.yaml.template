apiVersion: v1
kind: Secret
metadata:
  name: ai-market-studio-secrets
  namespace: default
type: Opaque
stringData:
  # Set to "dummy" because AI Gateway manages real OpenAI keys
  OPENAI_API_KEY: "dummy"
  # Replace with your actual key from exchangerate-api.com
  EXCHANGERATE_API_KEY: "<your-exchangerate-api-key-here>"
